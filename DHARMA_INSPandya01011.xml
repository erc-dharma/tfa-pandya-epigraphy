            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                
                
                <lg n="1" met="aṟucīrkkaḻineṭilaṭi yāciriyaviruttam">
                    <l n="a"><lb n="1"/>cakaṉ kālam āyirattu nāṉūṟṟ' e
                    <lb n="2" break="no"/>ṇpatt' āṟiṟ calati cūḻnta</l>
                    <l n="b">ceka
                    <lb n="3" break="no"/>ṅkāṇa virattākki cittirai
                    <lb n="4" break="no"/>yil irupatān tēti vēntar</l>
                    <l n="c"><lb n="5"/>pukaḻntēval ceya-p-pūṟuva
                    <lb n="6" break="no"/>-titi y-āṟil mutal vāram puṇar
                    <lb n="7" break="no"/>pūcattiṟ</l>
                    <l n="d">cukant-āti-puṉai y-aḻakaṉ
                    <lb n="8"/>cīvala-vēḷ eṉa makuṭañ cūṭiṉāṉē</l>
                </lg>
                
                
            </div>
            
